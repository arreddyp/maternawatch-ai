# Copy this file to .env and fill in your values.
# Run the notification server with:
#   node -r dotenv/config notification-server.js

# ── Twilio credentials ───────────────────────────────────────────────────────
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# The WhatsApp sender number.
# Use the Twilio Sandbox number during development:
#   whatsapp:+14155238886
# In production, use your approved Twilio WhatsApp sender.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WhatsApp recipients to receive alerts.
# Format: whatsapp:+<country_code><number>  (no spaces or dashes)
# Multiple recipients are supported with comma-separated values.
# Example: whatsapp:+919876543210,whatsapp:+919012345678
NOTIFY_WHATSAPP_TO=whatsapp:+919XXXXXXXXX

# Optional: risk score threshold (default 7). Alerts fire when score > this value.
RISK_THRESHOLD=7

# Optional: port for the notification server (default 8788)
NOTIFY_PORT=8788
